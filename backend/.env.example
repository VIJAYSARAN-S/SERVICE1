# Backend Environment Variables Template
# Production: Render + Neon Postgres

# Database Configuration
# Production: Use Neon Postgres connection string
# Local: Default will fall back to SQLite (sqlite:///./egov.db)
DATABASE_URL=postgresql://user:password@hostname/dbname?sslmode=require

# Security Configuration
# Generate a secret key using 'openssl rand -hex 32'
SECRET_KEY=your-super-secret-production-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Deployment URLs
# The public URL of your Vercel frontend deployment (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# The public URL of your Render backend deployment (used for media links)
BACKEND_URL=https://your-service.onrender.com

# System Configuration
ENVIRONMENT=production
PORT=8000
